{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oph.local/schemas/hadron/ward_projected_spectral_measure.schema.json",
  "title": "OPH Ward-projected hadronic spectral measure export",
  "type": "object",
  "required": [
    "artifact",
    "format_version",
    "profile_id",
    "branch",
    "projection",
    "backend",
    "finite_volume_levels",
    "ward_projected_residues",
    "rho_had_or_measure",
    "systematics",
    "guards"
  ],
  "properties": {
    "artifact": {
      "const": "oph_qcd_ward_projected_hadronic_spectral_measure"
    },
    "format_version": {
      "type": "integer",
      "minimum": 1
    },
    "profile_id": {
      "type": "string",
      "minLength": 1
    },
    "branch": {
      "type": "object",
      "required": ["flavors", "qed"],
      "properties": {
        "flavors": {"const": "2+1"},
        "qed": {"enum": ["off", "explicitly_superseded"]}
      },
      "additionalProperties": true
    },
    "projection": {
      "type": "object",
      "required": ["lane", "ward_projected", "external_kinematics", "zero_momentum_endpoint_compatible"],
      "properties": {
        "lane": {"const": "U(1)_Q"},
        "ward_projected": {"const": true},
        "external_kinematics": {"type": "string", "minLength": 1},
        "zero_momentum_endpoint_compatible": {"const": true}
      },
      "additionalProperties": true
    },
    "backend": {
      "type": "object",
      "required": ["family", "name", "version", "git_commit", "run_id", "build_id", "machine"],
      "properties": {
        "family": {"type": "string", "minLength": 1},
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "git_commit": {"type": "string", "minLength": 1},
        "run_id": {"type": "string", "minLength": 1},
        "build_id": {"type": "string", "minLength": 1},
        "machine": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    },
    "finite_volume_levels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["ensemble_id", "channel", "levels"],
        "properties": {
          "ensemble_id": {"type": "string", "minLength": 1},
          "channel": {"type": "string", "minLength": 1},
          "levels": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["level_id", "s", "energy", "weight"],
              "properties": {
                "level_id": {"type": "string", "minLength": 1},
                "s": {"type": "number"},
                "energy": {"type": "number"},
                "weight": {"type": "number"}
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "ward_projected_residues": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["level_id", "residue", "current_normalization"],
        "properties": {
          "level_id": {"type": "string", "minLength": 1},
          "residue": {"type": "number"},
          "current_normalization": {"type": "string", "minLength": 1}
        },
        "additionalProperties": true
      }
    },
    "rho_had_or_measure": {
      "type": "object",
      "required": ["representation", "support_variable", "pushforward_rule", "positivity_status"],
      "properties": {
        "representation": {"enum": ["rho_had", "primitive_spectral_measure"]},
        "support_variable": {"const": "s"},
        "pushforward_rule": {"type": "string", "minLength": 1},
        "positivity_status": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    },
    "systematics": {
      "type": "object",
      "required": [
        "statistical_budget",
        "continuum_budget",
        "finite_volume_budget",
        "chiral_budget",
        "current_matching_budget",
        "quadrature_budget",
        "endpoint_remainder_budget"
      ],
      "properties": {
        "statistical_budget": {"type": "object"},
        "continuum_budget": {"type": "object"},
        "finite_volume_budget": {"type": "object"},
        "chiral_budget": {"type": "object"},
        "current_matching_budget": {"type": "object"},
        "quadrature_budget": {"type": "object"},
        "endpoint_remainder_budget": {"type": "object"}
      },
      "additionalProperties": true
    },
    "guards": {
      "type": "object",
      "required": [
        "stable_channel_only",
        "surrogate_hadron_artifact",
        "compare_only_external_endpoint"
      ],
      "properties": {
        "stable_channel_only": {"const": false},
        "surrogate_hadron_artifact": {"const": false},
        "compare_only_external_endpoint": {"const": false}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oph.local/schemas/hadron/ward_projected_spectral_measure.schema.json",
  "title": "OPH Ward-projected hadronic spectral measure export (strict production contract)",
  "description": "Strict fail-closed production export contract. Every object boundary is closed (additionalProperties: false), provenance is a required typed manifest cross-referenced to the ensemble ids, the physical premises (gauge-quotient ensemble, conserved current / normalization matching, Ward identity, reflection positivity / transfer) are required typed certificate references pinned by LF-normalized sha256, channels and normalization conventions are allowlisted enums, the format version is pinned, and the covariance block and the transport-moment certificate required by the downstream source-transport consumer are mandatory. Semantic constraints that JSON Schema cannot express (finiteness, s = energy^2, identifier integrity, residue/weight consistency, covariance symmetry, positive semidefiniteness and per-level row coverage, ordered budget intervals, forbidden-token scan, certificate resolution and hash verification, provenance cross-references) are enforced by ward_projected_spectral_measure_validator.py; schema conformance alone is never acceptance.",
  "type": "object",
  "required": [
    "artifact",
    "format_version",
    "profile_id",
    "branch",
    "projection",
    "backend",
    "provenance",
    "premise_certificates",
    "external_targets_used",
    "finite_volume_levels",
    "ward_projected_residues",
    "rho_had_or_measure",
    "covariance",
    "transport_moment_certificate",
    "systematics",
    "guards"
  ],
  "additionalProperties": false,
  "properties": {
    "artifact": {
      "const": "oph_qcd_ward_projected_hadronic_spectral_measure"
    },
    "format_version": {
      "const": 2
    },
    "profile_id": {
      "type": "string",
      "minLength": 1
    },
    "branch": {
      "type": "object",
      "required": ["flavors", "qed"],
      "additionalProperties": false,
      "properties": {
        "flavors": {"const": "2+1"},
        "qed": {"enum": ["off", "explicitly_superseded"]}
      }
    },
    "projection": {
      "type": "object",
      "required": ["lane", "ward_projected", "external_kinematics", "zero_momentum_endpoint_compatible"],
      "additionalProperties": false,
      "properties": {
        "lane": {"const": "U(1)_Q"},
        "ward_projected": {"const": true},
        "external_kinematics": {"type": "string", "minLength": 1},
        "zero_momentum_endpoint_compatible": {"const": true}
      }
    },
    "backend": {
      "type": "object",
      "required": ["family", "name", "version", "git_commit", "run_id", "build_id", "machine"],
      "additionalProperties": false,
      "properties": {
        "family": {"type": "string", "minLength": 1},
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "git_commit": {"type": "string", "minLength": 1},
        "run_id": {"type": "string", "minLength": 1},
        "build_id": {"type": "string", "minLength": 1},
        "machine": {"type": "string", "minLength": 1}
      }
    },
    "provenance": {
      "type": "object",
      "required": ["source_inputs", "measured_hvp_input_present", "target_calibration_present"],
      "additionalProperties": false,
      "properties": {
        "source_inputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["kind", "identifier"],
            "additionalProperties": false,
            "properties": {
              "kind": {
                "enum": [
                  "bare_lattice_parameter",
                  "source_ensemble",
                  "oph_source_artifact",
                  "declared_convention",
                  "backend_provenance"
                ]
              },
              "identifier": {"type": "string", "minLength": 1}
            }
          }
        },
        "measured_hvp_input_present": {"const": false},
        "target_calibration_present": {"const": false}
      }
    },
    "premise_certificates": {
      "type": "object",
      "required": [
        "gauge_quotient_ensemble",
        "conserved_current_or_matching",
        "ward_identity",
        "reflection_positivity_transfer"
      ],
      "additionalProperties": false,
      "properties": {
        "gauge_quotient_ensemble": {
          "type": "object",
          "required": ["artifact", "path", "sha256"],
          "additionalProperties": false,
          "properties": {
            "artifact": {"const": "oph_qcd_source_ensemble_certificate"},
            "path": {"type": "string", "minLength": 1},
            "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
          }
        },
        "conserved_current_or_matching": {
          "type": "object",
          "required": ["artifact", "path", "sha256"],
          "additionalProperties": false,
          "properties": {
            "artifact": {"const": "oph_ward_current_source_certificate"},
            "path": {"type": "string", "minLength": 1},
            "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
          }
        },
        "ward_identity": {
          "type": "object",
          "required": ["artifact", "path", "sha256"],
          "additionalProperties": false,
          "properties": {
            "artifact": {"const": "oph_ward_identity_certificate"},
            "path": {"type": "string", "minLength": 1},
            "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
          }
        },
        "reflection_positivity_transfer": {
          "type": "object",
          "required": ["artifact", "path", "sha256"],
          "additionalProperties": false,
          "properties": {
            "artifact": {"const": "oph_reflection_positivity_transfer_certificate"},
            "path": {"type": "string", "minLength": 1},
            "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
          }
        }
      }
    },
    "external_targets_used": {
      "type": "array",
      "maxItems": 0,
      "items": {"type": "string"}
    },
    "finite_volume_levels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["ensemble_id", "channel", "levels"],
        "additionalProperties": false,
        "properties": {
          "ensemble_id": {"type": "string", "minLength": 1},
          "channel": {"enum": ["U(1)_Q_vector"]},
          "levels": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["level_id", "s", "energy", "weight"],
              "additionalProperties": false,
              "properties": {
                "level_id": {"type": "string", "minLength": 1},
                "s": {"type": "number", "minimum": 0},
                "energy": {"type": "number", "exclusiveMinimum": 0},
                "weight": {"type": "number", "minimum": 0},
                "energy_jackknife_error": {"type": "number", "minimum": 0},
                "weight_jackknife_error": {"type": "number", "minimum": 0}
              }
            }
          }
        }
      }
    },
    "ward_projected_residues": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["level_id", "residue", "current_normalization"],
        "additionalProperties": false,
        "properties": {
          "level_id": {"type": "string", "minLength": 1},
          "residue": {"type": "number", "minimum": 0},
          "current_normalization": {
            "type": "object",
            "required": ["convention", "certificate"],
            "additionalProperties": false,
            "properties": {
              "convention": {
                "enum": [
                  "conserved_current_ZV_equals_1",
                  "conserved_local_matching_certificate"
                ]
              },
              "certificate": {"const": "premise_certificates.conserved_current_or_matching"}
            }
          },
          "residue_jackknife_error": {"type": "number", "minimum": 0}
        }
      }
    },
    "rho_had_or_measure": {
      "type": "object",
      "required": ["representation", "support_variable", "pushforward_rule", "positivity_status", "positivity_certificate"],
      "additionalProperties": false,
      "properties": {
        "representation": {"enum": ["rho_had", "primitive_spectral_measure"]},
        "support_variable": {"const": "s"},
        "pushforward_rule": {"type": "string", "minLength": 1},
        "positivity_status": {"enum": ["certified_positive"]},
        "positivity_certificate": {"const": "premise_certificates.reflection_positivity_transfer"}
      }
    },
    "covariance": {
      "type": "object",
      "required": ["row_basis", "dimension", "matrix"],
      "additionalProperties": false,
      "properties": {
        "row_basis": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "dimension": {"type": "integer", "minimum": 1},
        "matrix": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "number"}
          }
        },
        "min_eigenvalue": {"type": "number"},
        "max_eigenvalue": {"type": "number"}
      }
    },
    "transport_moment_certificate": {
      "type": "object",
      "required": ["kernel", "Delta_had_image", "quadrature_error_bound", "tail_bound"],
      "additionalProperties": false,
      "properties": {
        "kernel": {"type": "string", "minLength": 1},
        "Delta_had_image": {
          "type": "object",
          "required": ["lo", "hi"],
          "additionalProperties": false,
          "properties": {
            "lo": {"type": ["number", "string"]},
            "hi": {"type": ["number", "string"]}
          }
        },
        "quadrature_error_bound": {"type": ["number", "string"]},
        "tail_bound": {"type": ["number", "string"]}
      }
    },
    "systematics": {
      "type": "object",
      "required": [
        "statistical_budget",
        "continuum_budget",
        "finite_volume_budget",
        "chiral_budget",
        "current_matching_budget",
        "quadrature_budget",
        "endpoint_remainder_budget"
      ],
      "additionalProperties": false,
      "properties": {
        "statistical_budget": {"$ref": "#/$defs/budget"},
        "continuum_budget": {"$ref": "#/$defs/budget"},
        "finite_volume_budget": {"$ref": "#/$defs/budget"},
        "chiral_budget": {"$ref": "#/$defs/budget"},
        "current_matching_budget": {"$ref": "#/$defs/budget"},
        "quadrature_budget": {"$ref": "#/$defs/budget"},
        "endpoint_remainder_budget": {"$ref": "#/$defs/budget"}
      }
    },
    "guards": {
      "type": "object",
      "required": [
        "stable_channel_only",
        "surrogate_hadron_artifact",
        "compare_only_external_endpoint"
      ],
      "additionalProperties": false,
      "properties": {
        "stable_channel_only": {"const": false},
        "surrogate_hadron_artifact": {"const": false},
        "compare_only_external_endpoint": {"const": false}
      }
    }
  },
  "$defs": {
    "budget": {
      "type": "object",
      "required": ["bound_interval"],
      "additionalProperties": false,
      "properties": {
        "bound_interval": {
          "type": "object",
          "required": ["lo", "hi"],
          "additionalProperties": false,
          "properties": {
            "lo": {"type": ["number", "string"]},
            "hi": {"type": ["number", "string"]}
          }
        },
        "method": {"type": "string", "minLength": 1}
      }
    }
  }
}
